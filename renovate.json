{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>grafana/grafana-renovate-config//presets/base",
        "schedule:weekly"
    ],
    "ignorePaths": [
        "config/*"
    ],
    "packageRules": [
        {
            "groupName": "golang",
            "description": "Golang packages",
            "matchManagers": [
                "gomod"
            ],
            "enabled": true,
            "postUpdateOptions": [
                "gomodTidy",
                "gomodUpdateImportPaths"
            ]
        },
        {
            "description": "No indirect dependencies",
            "matchManagers": [
                "gomod"
            ],
            "matchDepTypes": [
                "indirect"
            ],
            "enabled": false
        },
        {
            "groupName": "kubernetes-major-minor",
            "description": "Kubernetes Golang packages, major and minor versions",
            "matchManagers": [
                "gomod"
            ],
            "matchPackageNames": [
                "sigs.k8s.io/controller-runtime",
                "k8s.io/*"
            ],
            "extends": [
                "schedule:quarterly"
            ],
            "matchUpdateTypes": [
                "minor",
                "major"
            ],
            // NOTE: we aren't allowed to set `postUpgradeTasks` at this point of time. 
            // The automated PR might be invalid without it and require manual intervention.
            "enabled": true
        },
        {
            "groupName": "kubernetes-patch",
            "description": "Kubernetes Golang packages, patch versions",
            "matchManagers": [
                "gomod"
            ],
            "matchPackageNames": [
                "sigs.k8s.io/controller-runtime",
                "k8s.io/*"
            ],
            "matchUpdateTypes": [
                "patch"
            ],
            "enabled": true
        },
        {
            "groupName": "k6-golang",
            "description": "k6 Golang packages",
            "matchManagers": [
                "gomod"
            ],
            "matchPackageNames": [
                "go.k6.io/k6"
            ]
        },
        {
            "description": "Disable updates",
            "matchManagers": [
                "gomod"
            ],
            "enabled": false,
            "matchPackageNames": [
                "github.com/sirupsen/logrus"
            ]
        },
        {
            "description": "Github actions",
            "matchManagers": [
                "github-actions"
            ],
            "extends": [
                "schedule:monthly"
            ]
        },
        {
            "description": "Github actions: by releases only",
            "matchManagers": [
                "github-actions"
            ],
            "matchPackageNames": [
                "github.com/Azure/setup-helm"
            ],
            "matchUpdateTypes": [
                "digest"
            ],
            "enabled": false
        }
    ]
}